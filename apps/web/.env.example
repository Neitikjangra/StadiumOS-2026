# =============================================================================
# StadiumOS 2026 — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================================================

# --- Authentication ---
# REQUIRED: Secret for JWT signing. Generate with: openssl rand -base64 32
AUTH_SECRET=changeme-generate-a-real-secret
NEXTAUTH_SECRET=changeme-generate-a-real-secret
AUTH_TRUST_HOST=true

# --- Database ---
# SQLite file path (relative to project root)
DATABASE_URL="file:./dev.db"

# --- Redis (optional — app runs without it, queue/socket features disabled) ---
# REDIS_URL=redis://localhost:6379

# --- Public App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI Provider (optional — app runs with fallback responses) ---
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# --- Security Notes ---
# - AUTH_SECRET and NEXTAUTH_SECRET must be different in production
# - Rotate secrets periodically
# - Use environment-specific values, never hardcode
# - REDIS_URL should use rediss:// protocol with TLS in production
# - OPENAI_API_KEY should have restricted permissions
